# Caddyfile for CADE (Secure Remote Deployment)
# Automatically handles HTTPS certificates via Let's Encrypt

{$CADE_DOMAIN:cade.yourdomain.com} {
    # Reverse proxy to the local CADE backend
    reverse_proxy 127.0.0.1:8284 {
        # Disable buffering to allow SSE streams to flow instantly
        flush_interval -1
        
        header_up Connection keep-alive
        header_up Cache-Control no-cache
        
        # Extended timeouts for long-running agentic tasks
        transport http {
            read_timeout 1h
            write_timeout 1h
            keepalive 1h
        }
    }
}
